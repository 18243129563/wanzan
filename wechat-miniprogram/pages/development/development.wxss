/* pages/development/development.wxss */

.dev-root-viewport {
  padding: 12px 20px 40px;
  background-color: #FBFDF8;
  min-height: 100vh;
  box-sizing: border-box;
}

.dev-header {
  display: flex;
  flex-direction: column;
}

.dev-title {
  font-size: 24px;
  font-weight: 900;
  color: #191C1A;
  margin-bottom: 6px;
  letter-spacing: -0.5px;
}

.dev-subtitle {
  font-size: 11px;
  color: #747878;
  font-weight: bold;
}

.divider-line {
  height: 1px;
  background-color: rgba(116, 120, 120, 0.15);
  width: 100%;
  margin-top: 16px;
}

/* Sections */
.section-title-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 16px;
}

.badge-tag {
  width: 4px;
  height: 14px;
  border-radius: 4px;
}

.bg-primary { background-color: #446732; }
.bg-brown { background-color: #7A5749; }

.section-title-text {
  font-size: 11px;
  font-weight: 800;
  color: #747878;
  letter-spacing: 1px;
}

/* Tools Grid */
.dev-tools-grid {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.dev-tool-card {
  background-color: #ffffff;
  border-radius: 20px;
  padding: 14px 16px;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  position: relative;
}

.border {
  border: 1px solid rgba(116, 120, 120, 0.11);
}

.shadow-sm {
  box-shadow: 0 2px 8px rgba(0,0,0,0.03);
}

.dev-icon-block {
  width: 44px;
  height: 44px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 14px;
  flex-shrink: 0;
}

.dev-icon-emoji {
  font-size: 22px;
  line-height: 1;
}

.dev-card-info {
  flex-grow: 1;
  display: flex;
  flex-direction: column;
  padding-right: 16px;
}

.dev-tool-name {
  font-size: 14px;
  font-weight: 700;
  color: #191C1A;
  margin-bottom: 2px;
}

.dev-tool-desc {
  font-size: 11px;
  color: #747878;
  line-height: 1.4;
}

.action-chevron {
  font-size: 11px;
  color: #747878;
  opacity: 0.5;
  flex-shrink: 0;
}

.mt-4 { margin-top: 16px; }
.mt-6 { margin-top: 24px; }
