/* pages/index/index.wxss */
.container {
  padding: 40rpx 30rpx 60rpx;
  background-color: #FCF7F2;
}

/* Brand styling */
.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
  text-align: center;
}

.logo-box {
  width: 120rpx;
  height: 120rpx;
  border-radius: 40rpx;
  background-color: rgba(27, 67, 50, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  border: 4rpx solid #1b4332;
  box-shadow: 0 8rpx 24rpx rgba(27, 67, 50, 0.06);
}

.leaf-icon {
  font-size: 60rpx;
}

.brand-title {
  font-size: 48rpx;
  font-weight: 900;
  color: #1b4332;
  letter-spacing: -1rpx;
}

.brand-subtitle {
  font-size: 24rpx;
  font-weight: bold;
  color: #7a5749;
  margin-top: 8rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.version-tag {
  font-size: 20rpx;
  color: #1b4332;
  background-color: rgba(27, 67, 50, 0.06);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-weight: bold;
  margin-top: 14rpx;
  border: 1rpx solid rgba(27, 67, 50, 0.1);
}

/* Feature card stats */
.feature-card {
  padding: 40rpx 32rpx;
}

.feature-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #1b4332;
  margin-bottom: 12rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: #727272;
  line-height: 1.6;
  margin-bottom: 30rpx;
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 24rpx 0;
  background-color: #FBF8F5;
  border-radius: 20rpx;
  border: 1rpx solid rgba(27, 67, 50, 0.04);
  margin-bottom: 30rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-count {
  font-size: 36rpx;
  font-weight: 900;
  color: #1b4332;
}

.stat-label {
  font-size: 20rpx;
  font-weight: bold;
  color: #7e7e7e;
  margin-top: 4rpx;
}

.stat-line {
  width: 1rpx;
  height: 60rpx;
  background-color: rgba(27, 67, 50, 0.1);
}

.bullet-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.bullet-item {
  display: flex;
  align-items: flex-start;
}

.bullet-dot {
  color: #1b4332;
  font-size: 24rpx;
  margin-right: 12rpx;
  font-weight: bold;
  line-height: 1.2;
}

.bullet-text {
  font-size: 24rpx;
  color: #555555;
  line-height: 1.5;
}

.highlight {
  font-weight: bold;
  color: #1b4332;
}

/* Button & entry triggers */
.cta-block {
  margin: 32rpx 0 44rpx;
}

.open-btn {
  width: 100% !important;
  font-size: 32rpx;
  padding: 28rpx 0;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.secondary-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.btn-secondary {
  flex: 1;
  background-color: #ffffff;
  color: #1b4332;
  border: 1rpx solid rgba(27, 67, 50, 0.2);
  border-radius: 36rpx;
  font-size: 26rpx;
  font-weight: bold;
  padding: 18rpx 0;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.01);
}

.btn-secondary:active {
  background-color: #f7f7f7;
  transform: scale(0.98);
}

/* Previews Grid list */
.preview-header {
  font-size: 28rpx;
  font-weight: 900;
  color: #1b4332;
  margin: 16rpx 0 20rpx 4rpx;
  letter-spacing: 1rpx;
}

.grid-container {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.grid-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx 20rpx;
  border: 1rpx solid rgba(27, 67, 50, 0.05);
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.01);
  display: flex;
  flex-direction: column;
}

.grid-icon {
  font-size: 38rpx;
  margin-bottom: 12rpx;
}

.grid-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #1B4332;
}

.grid-info {
  font-size: 18rpx;
  color: #888888;
  margin-top: 4rpx;
}

.nav-footer {
  text-align: center;
  margin-top: 60rpx;
}

.nav-footer text {
  font-size: 18rpx;
  font-weight: bold;
  color: #9C9086;
  letter-spacing: 1rpx;
}
