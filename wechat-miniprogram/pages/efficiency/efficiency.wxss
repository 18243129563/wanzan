/* pages/efficiency/efficiency.wxss */
.tool-list {
  display: flex;
  flex-direction: column;
}
.tool-item {
  display: flex;
  background: white;
  padding: 16px;
  border-radius: 12px;
  margin-bottom: 12px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.05);
}
.tool-item-icon {
  width: 40px;
  height: 40px;
  border-radius: 8px;
  margin-right: 16px;
}
.tool-item-content {
  display: flex;
  flex-direction: column;
}
.tool-item-name {
  font-size: 16px;
  font-weight: 500;
  margin-bottom: 4px;
}
.tool-item-desc {
  font-size: 12px;
  color: #747878;
}
