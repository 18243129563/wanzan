<!--pages/efficiency/efficiency.wxml-->
<view class="eff-root-viewport animate-[fadeIn_0.5s]">
  
  <!-- Header meta -->
  <view class="eff-header">
    <text class="eff-title">自律生产力</text>
    <text class="eff-subtitle">专注打理您的日常心流任务，多维拓展认知。</text>
    <view class="divider-line"></view>
  </view>

  <!-- Section 1: Time efficiency -->
  <view class="eff-section mt-4">
    <view class="title-decor">
      <view class="decor-dot bg-p"></view>
      <text class="decor-text">时间效率 (CHRONOSPACE)</text>
    </view>
    
    <view class="eff-grid">
      <view 
        class="eff-card border shadow-sm" 
        wx:for="{{timeTools}}" 
        wx:key="id" 
        bindtap="onToolSelect" 
        data-id="{{item.id}}"
      >
        <view class="eff-badge" style="background-color: {{item.colorBg}};">
          <text class="eff-emoji">{{item.iconArt}}</text>
        </view>
        <view class="eff-details">
          <text class="eff-name">{{item.name}}</text>
          <text class="eff-desc">{{item.desc}}</text>
        </view>
        <text class="btn-chevron">➔</text>
      </view>
    </view>
  </view>

  <!-- Section 2: Study and Creation -->
  <view class="eff-section mt-6">
    <view class="title-decor">
      <view class="decor-dot bg-s"></view>
      <text class="decor-text font-serif">文字创作与学习小筑 (LABS)</text>
    </view>
    
    <view class="eff-grid">
      <view 
        class="eff-card border shadow-sm" 
        wx:for="{{creativeTools}}" 
        wx:key="id" 
        bindtap="onToolSelect" 
        data-id="{{item.id}}"
      >
        <view class="eff-badge" style="background-color: {{item.colorBg}};">
          <text class="eff-emoji">{{item.iconArt}}</text>
        </view>
        <view class="eff-details">
          <text class="eff-name">{{item.name}}</text>
          <text class="eff-desc">{{item.desc}}</text>
        </view>
        <text class="btn-chevron">➔</text>
      </view>
    </view>
  </view>

  <!-- Section 3: Document converters -->
  <view class="eff-section mt-6">
    <view class="title-decor">
      <view class="decor-dot bg-t"></view>
      <text class="decor-text">文档转换辅助 (CONVERTERS)</text>
    </view>
    
    <view class="eff-grid">
      <view 
        class="eff-card border shadow-sm" 
        wx:for="{{docTools}}" 
        wx:key="id" 
        bindtap="onToolSelect" 
        data-id="{{item.id}}"
      >
        <view class="eff-badge" style="background-color: {{item.colorBg}};">
          <text class="eff-emoji">{{item.iconArt}}</text>
        </view>
        <view class="eff-details">
          <text class="eff-name">{{item.name}}</text>
          <text class="eff-desc">{{item.desc}}</text>
        </view>
        <text class="btn-chevron">➔</text>
      </view>
    </view>
  </view>

</view>
