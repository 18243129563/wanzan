/* pages/profile/profile.wxss */

.profile-viewport {
  padding: 16px 20px 40px;
  background-color: #FBFDF8;
  min-height: 100vh;
  box-sizing: border-box;
}

/* Auth Card and Avatar block */
.profile-auth-section {
  background-color: #ffffff;
  border-radius: 28px;
  padding: 24px 20px;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  margin-top: 12px;
}

.border {
  border: 1px solid rgba(116, 120, 120, 0.11);
}

.shadow-sm {
  box-shadow: 0 2px 8px rgba(0,0,0,0.03);
}

.avatar-ring {
  position: relative;
  width: 76px;
  height: 76px;
  border-radius: 50%;
  padding: 3px;
  background-color: #F1F3EE;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 18px;
  flex-shrink: 0;
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background-color: #E8F5E9;
}

.avatar-pencil-badge {
  position: absolute;
  bottom: -2px;
  right: -2px;
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background-color: #446732;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  box-shadow: 0 2px 6px rgba(0,0,0,0.1);
}

.auth-details {
  flex-grow: 1;
  display: flex;
  flex-direction: column;
}

.user-name-title {
  font-size: 18px;
  font-weight: 800;
  color: #191C1A;
  margin-bottom: 4px;
}

.user-sub-label {
  font-size: 11px;
  color: #446732;
  font-weight: bold;
}

.btn-micro-login {
  background-color: #446732 !important;
  color: #ffffff !important;
  font-size: 11px;
  font-weight: bold;
  height: 28px;
  line-height: 28px;
  padding: 0 12px;
  border-radius: 40px;
  width: auto !important;
  margin: 4px 0 0 0 !important;
}

/* Menu rows */
.menu-list-card {
  background-color: #ffffff;
}

.menu-list-row {
  display: flex;
  align-items: center;
  padding: 16px 20px;
  box-sizing: border-box;
}

.border-b {
  border-bottom: 1px solid rgba(116, 120, 120, 0.08);
}

.row-icon {
  width: 38px;
  height: 38px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  margin-right: 14px;
  flex-shrink: 0;
}

.bg-primary { background-color: rgba(68, 103, 50, 0.12); color: #446732; }
.bg-secondary { background-color: rgba(122, 87, 73, 0.12); color: #7A5749; }

.row-text-block {
  flex-grow: 1;
  display: flex;
  flex-direction: column;
}

.row-heading {
  font-size: 14px;
  font-weight: bold;
  color: #191C1A;
  margin-bottom: 2px;
}

.row-subtitle {
  font-size: 10px;
  color: #747878;
}

.chevron-arrow {
  font-size: 11px;
  color: #747878;
  opacity: 0.5;
}

.logout-action-dock {
  width: 100%;
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 100px;
  font-size: 14px;
  font-weight: bold;
  height: 48px;
  box-shadow: none;
  width: 100%;
  box-sizing: border-box;
}

.btn-neutral {
  background-color: #F1F3EE;
  color: #191C1A;
}

.text-error {
  color: #BA1A1A !important;
}

/* ==========================================
   MODAL DIALOG VIEWS (Mask overlays & Cards)
   ========================================== */
.modal-mask-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(25, 28, 26, 0.6);
  backdrop-filter: blur(8px);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px;
  box-sizing: border-box;
}

.modal-modal-card {
  position: relative;
  width: 100%;
  max-width: 460px;
  background-color: #ffffff;
  border-radius: 32px;
  padding: 24px;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  max-height: 85vh;
}

.shadow-2xl {
  box-shadow: 0 10px 40px rgba(0,0,0,0.12);
}

.modal-close-round {
  position: absolute;
  top: 18px;
  right: 18px;
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background-color: #F1F3EE;
  color: #191C1A;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  padding: 0;
  margin: 0;
  line-height: 1;
  border: none;
  z-index: 10;
}

/* About Layout details */
.about-brand-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  margin-top: 12px;
}

.brand-badge {
  width: 58px;
  height: 58px;
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26px;
  margin-bottom: 12px;
}

.bg-primary-container { background-color: #D3E8D0; }
.text-primary { color: #446732; }

.about-main-title {
  font-size: 24px;
  font-weight: 900;
  color: #446732;
  margin-bottom: 2px;
}

.about-motto {
  font-size: 11px;
  color: #191C1A;
  font-weight: bold;
}

.about-tag {
  font-size: 9px;
  font-family: monospace;
  color: #747878;
  padding: 2px 8px;
  background-color: #F1F3EE;
  border-radius: 4px;
  margin-top: 6px;
  border: 1px solid rgba(116, 120, 120, 0.1);
}

.decor-line {
  height: 1px;
  background-color: rgba(116, 120, 120, 0.12);
  width: 100%;
}

.about-scroll-body {
  width: 100%;
  flex-grow: 1;
  max-height: 40vh;
}

.about-card-section {
  display: flex;
  flex-direction: column;
  margin-bottom: 16px;
}

.section-badge-left {
  font-size: 11px;
  font-weight: 800;
  color: #446732;
  border-left: 3px solid #446732;
  padding-left: 8px;
  margin-bottom: 8px;
}

.section-p {
  font-size: 12px;
  color: #747878;
  line-height: 1.6;
  text-align: justify;
  margin-bottom: 8px;
}

.about-sub-grid {
  display: flex;
}

.grid-subcard {
  padding: 10px;
  border-radius: 12px;
  background-color: #FBFDF8;
}

.subcard-title {
  font-size: 11px;
  font-weight: bold;
  color: #191C1A;
  margin-bottom: 4px;
  display: block;
}

.subcard-p {
  font-size: 9px;
  color: #747878;
  line-height: 1.4;
  display: block;
}

.about-meta-footer {
  display: flex;
  flex-direction: column;
  text-align: center;
  font-size: 9px;
  color: #747878;
  gap: 2px;
}

/* Logs design */
.logs-header {
  display: flex;
  flex-direction: column;
}

.logs-title {
  font-size: 16px;
  font-weight: bold;
  color: #191C1A;
  margin-bottom: 4px;
}

.logs-subtitle {
  font-size: 10px;
  color: #747878;
}

.logs-scroll-viewport {
  width: 100%;
  flex-grow: 1;
  max-height: 48vh;
}

.log-row {
  background-color: #FBFDF8;
  border-radius: 16px;
  padding: 12px 14px;
  margin-bottom: 8px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-sizing: border-box;
}

.log-main {
  display: flex;
  flex-direction: column;
}

.log-desc {
  font-size: 12px;
  font-weight: bold;
  color: #191C1A;
  margin-bottom: 2px;
}

.log-time {
  font-size: 10px;
  color: #747878;
}

.status-green {
  font-size: 10px;
  font-weight: bold;
  color: #446732;
  padding: 2px 6px;
  background-color: #E8F5E9;
  border-radius: 4px;
}

.empty-logs {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.empty-icon-art {
  font-size: 32px;
  margin-bottom: 8px;
}

.empty-title {
  font-size: 13px;
  font-weight: bold;
  color: #191C1A;
  margin-bottom: 4px;
}

.empty-sub {
  font-size: 10px;
  color: #747878;
}

.logs-action-row {
  display: flex;
}

/* Animations */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from { transform: translateY(30px); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.animate-fade {
  animation: fadeIn 0.25s forwards ease-out;
}

.animate-slideUp {
  animation: slideUp 0.33s forwards cubic-bezier(0.16, 1, 0.3, 1);
}

.text-mono {
  font-family: monospace;
}

.flex-row { display: flex; flex-direction: row; }
.flex-col { display: flex; flex-direction: column; }
.flex-1 { flex: 1; }
.gap-3 { gap: 12px; }

.mt-6 { margin-top: 24px; }
.mt-4 { margin-top: 16px; }
.mb-4 { margin-bottom: 16px; }
.pt-2 { padding-top: 8px; }
.pb-2 { padding-bottom: 8px; }
