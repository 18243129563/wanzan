<!--pages/profile/profile.wxml-->
<view class="profile-viewport animate-[fadeIn_0.5s]">
  
  <!-- Personal Profile Card -->
  <view class="profile-auth-section shadow-sm border" bindtap="onLogin">
    <view class="avatar-ring animate-fade">
      <image 
        class="avatar-image" 
        src="{{isLoggedIn ? userInfo.avatarUrl : 'https://api.dicebear.com/7.x/notionists/svg?seed=Mimi&backgroundColor=e6f4ea'}}" 
        mode="aspectFill"
      ></image>
      <view class="avatar-pencil-badge">✍</view>
    </view>
    
    <view class="auth-details">
      <text class="user-name-title">{{isLoggedIn ? userInfo.nickName : '游客账户'}}</text>
      <text class="user-sub-label" wx:if="{{isLoggedIn}}">已通过 Spring Nest 账号验证</text>
      <button class="btn-micro-login" wx:else>点击安全登录</button>
    </view>
  </view>

  <!-- Interactive Menu Row container -->
  <view class="menu-list-card mt-6 border shadow-sm rounded-3xl pb-2 pt-2">
    
    <!-- Row 1: My Favorites -->
    <view class="menu-list-row border-b" bindtap="toggleHistory" data-show="true">
      <view class="row-icon bg-secondary">⏱</view>
      <view class="row-text-block">
        <text class="row-heading">使用记录</text>
        <text class="row-subtitle">近期小工具的点击使用汇总</text>
      </view>
      <text class="chevron-arrow">➔</text>
    </view>

    <!-- Row 2: About Spring Nest -->
    <view class="menu-list-row" bindtap="toggleAbout" data-show="true">
      <view class="row-icon bg-primary">☘</view>
      <view class="row-text-block">
        <text class="row-heading">关于春日小筑</text>
        <text class="row-subtitle">高致美学数字工具家园 · V1.0.0</text>
      </view>
      <text class="chevron-arrow">➔</text>
    </view>

  </view>

  <!-- Logout segment -->
  <view class="logout-action-dock mt-6" wx:if="{{isLoggedIn}}">
    <button class="btn btn-neutral text-error font-bold border" bindtap="onLogout">退出登录</button>
  </view>


  <!-- ==========================================
       MODAL: ABOUT SPRING NEST OVERLAY
       ========================================== -->
  <view class="modal-mask-overlay animate-fade" wx:if="{{showAboutModal}}" bindtap="toggleAbout" data-show="false">
    <view class="modal-modal-card animate-slideUp border shadow-2xl" catchtap="none">
      
      <!-- Close action -->
      <button class="modal-close-round" bindtap="toggleAbout" data-show="false">×</button>

      <!-- Brand Header -->
      <view class="about-brand-wrap">
        <view class="brand-badge bg-primary-container text-primary">🌿</view>
        <text class="about-main-title font-serif">春日小筑</text>
        <text class="about-motto">Spring Nest · 高致美学数字家园</text>
        <text class="about-tag">V1.0.0 Stable Release</text>
      </view>

      <view class="decor-line mb-4 mt-4"></view>

      <!-- Narrative -->
      <scroll-view scroll-y class="about-scroll-body flex flex-col gap-4">
        
        <view class="about-card-section">
          <text class="section-badge-left">设计初心与起源</text>
          <text class="section-p">在这个算法纷呈、信息过载的喧嚣时代，每日的指尖流转中充斥着太多无序的推送与过度设计的冗繁应用。<strong>「春日小筑」</strong> 是一方为您用心精筑的雅致工具港湾。我们深信，日常使用的工具不应当是碎片化注意力的掠夺者，而应当是以极致美感滋养心智的静谧助手。</text>
          <text class="section-p">为此，我们倾注心血为您雕琢了这里的每一个界面切片、每一抹明暗过渡与每一丝微小的自如微动效。每一次开启都旨在伴您安享当下、悠然生活。</text>
        </view>

         <view class="about-card-section">
          <text class="section-badge-left">核心两大坚守</text>
          <view class="about-sub-grid flex-row gap-3">
            <view class="grid-subcard border flex-1">
              <text class="subcard-title">✦ 匠心至臻美学</text>
              <text class="subcard-p">打磨温润如纸的 off-white 灰白色温与灰炭色阶，摒弃毫无情绪的刺眼冷光，呈现恰到其份的典雅工艺视觉张力。</text>
            </view>
            <view class="grid-subcard border flex-1">
              <text class="subcard-title">✦ 纯粹自如无扰</text>
              <text class="subcard-p">绝无侵入式的广告打扰，没有喋喋不休的后台推送。闲置时安分、静下且绝不平添一分喧杂。</text>
            </view>
          </view>
        </view>

      </scroll-view>

      <view class="decor-line mb-4 mt-4"></view>

      <view class="about-meta-footer">
        <text>© 2026 Spring Nest · Powered by TLS 1.3</text>
        <text>安宁 · 优美 · 数据通道强安全级防护</text>
      </view>

    </view>
  </view>


  <!-- ==========================================
       MODAL: HISTORY LOGS OVERLAY
       ========================================== -->
  <view class="modal-mask-overlay animate-fade" wx:if="{{showHistoryModal}}" bindtap="toggleHistory" data-show="false">
    <view class="modal-modal-card animate-slideUp border shadow-2xl" catchtap="none">
      
      <!-- Close action -->
      <button class="modal-close-round" bindtap="toggleHistory" data-show="false">×</button>

      <!-- Logs title -->
      <view class="logs-header">
        <text class="logs-title">最近使用记录</text>
        <text class="logs-subtitle">记录近期在此端设备上，小工具的点击使用活动。</text>
      </view>

      <view class="decor-line mb-4 mt-4"></view>

      <!-- Logs List Scroll Container -->
      <scroll-view scroll-y class="logs-scroll-viewport">
        <block wx:if="{{historyLogs.length > 0}}">
          <view class="log-row border" wx:for="{{historyLogs}}" wx:key="id">
            <view class="log-main">
              <text class="log-desc">{{item.desc}}</text>
              <text class="log-time text-mono">{{item.time}}</text>
            </view>
            <view class="status-green">✓ 已记录</view>
          </view>
        </block>

        <view class="empty-logs flex flex-col items-center justify-center py-12" wx:else>
          <text class="empty-icon-art">📦</text>
          <text class="empty-title">尚无使用活动汇总</text>
          <text class="empty-sub">开启微信小程序工具，使用详情将自动陈列于此~</text>
        </view>
      </scroll-view>

      <view class="decor-line mb-4 mt-4"></view>

      <!-- Action items -->
      <view class="logs-action-row pt-2 flex-row gap-3">
        <button class="btn btn-neutral border flex-1" bindtap="toggleHistory" data-show="false">关闭日志</button>
        <button class="btn btn-primary bg-primary flex-1" bindtap="clearHistory" wx:if="{{historyLogs.length > 0}}">清空设备历史</button>
      </view>

    </view>
  </view>

</view>
