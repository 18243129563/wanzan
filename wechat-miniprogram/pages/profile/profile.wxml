<!--pages/profile/profile.wxml-->
<view class="container profile-container">
  <view class="avatar-section" bindtap="onLogin">
    <image class="avatar" src="{{isLoggedIn ? userInfo.avatarUrl : '../../assets/images/default_avatar.png'}}" mode="aspectFill"></image>
    <view class="user-info">
      <text class="nickname">{{isLoggedIn ? userInfo.nickName : '点击登录/注册'}}</text>
      <text class="slogan" wx:if="{{isLoggedIn}}">遇见世界上最美的风景</text>
      <text class="slogan" wx:else>登录以使用更多功能</text>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item">
      <text>同步数据</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item">
      <text>语言</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item">
      <text>暗色模式</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item">
      <text>设置</text>
      <text class="arrow">></text>
    </view>
  </view>
</view>
