<!--pages/tool/tool.wxml-->
<view class="tool-view-container">
  
  <!-- Tool Universal Header block -->
  <view class="tool-badge-card">
    <text class="tool-meta-title">{{toolName}}</text>
    <text class="tool-meta-desc">{{toolDesc}}</text>
    <view class="divider-line"></view>
  </view>

  <!-- ROOT INJECTED MODULES -->
  <view class="tool-active-canvas">

    <!-- FALLBACK/UNDER CONSTRUCTION SCREEN -->
    <view class="fallback-frame" wx:if="{{isFallback}}">
      <view class="fallback-icon">✦</view>
      <text class="fallback-heading">匠心打磨中</text>
      <text class="fallback-paragraph">我们正精打细磨该端上的这个小筑随身工具。我们将尽快在后续的更新版本中，将该完整体验推送到您的微信小程序上！</text>
    </view>

    <!-- 1) JSON FORMAT LAB -->
    <view class="tool-card json-lab" wx:if="{{toolId === 'json-formatter'}}">
      <view class="input-deck">
        <text class="section-badge">原始数据 (RAW JSON)</text>
        <textarea 
          class="raw-json-textarea text-mono" 
          placeholder='在此输入或粘贴需要校验的 JSON 数据，例如: {"name":"Spring Nest","build":2026}'
          value="{{jsonInput}}"
          bindinput="onJsonInput"
          maxlength="-1"
        ></textarea>
      </view>

      <view class="action-dock flex-row pb-3 pt-3">
        <button class="btn btn-primary" bindtap="formatJson">开始校验与格式化</button>
      </view>

      <view class="result-deck {{jsonError ? 'border-error' : ''}}">
        <view class="result-header">
          <text class="result-title {{jsonError ? 'text-error' : ''}}">{{jsonError ? '⚠️ 校验错误提示' : '美化数据 (BEAUTIFIED)'}}</text>
          <button 
            class="btn-text" 
            wx:if="{{jsonOutput && !jsonError}}" 
            data-text="{{jsonOutput}}" 
            data-key="json-copy"
            bindtap="copyText"
          >{{copiedKey === 'json-copy' ? '已复制 ✔' : '完整复制'}}</button>
        </view>
        <view class="scroll-wrap text-mono text-error font-medium" wx:if="{{jsonError}}">
          <text>{{jsonError}}</text>
        </view>
        <textarea 
          class="beautified-textarea text-mono text-success" 
          wx:else 
          placeholder="格式化结果输出..." 
          value="{{jsonOutput}}" 
          disabled 
          maxlength="-1"
        ></textarea>
      </view>
    </view>

    <!-- 2) BASE64 TOOL -->
    <view class="tool-card base64-lab" wx:if="{{toolId === 'base64-codec'}}">
      <view class="input-deck">
        <text class="section-badge">输入字符 (INPUT RAW)</text>
        <textarea 
          class="raw-json-textarea text-mono" 
          placeholder='在此输入你要编解码的普通文本或 Base64 字符串...'
          value="{{base64Input}}"
          bindinput="onBase64Input"
          maxlength="-1"
        ></textarea>
      </view>

      <view class="grid-buttons flex-row">
        <button class="btn btn-primary flex-1" bindtap="base64Encode">加密 (Encode)</button>
        <button class="btn btn-secondary flex-1" bindtap="base64Decode">解密 (Decode)</button>
      </view>

      <view class="result-deck">
        <view class="result-header">
          <text class="result-title">转换输出 (CONVERTED RESULT)</text>
          <button 
            class="btn-text" 
            wx:if="{{base64Output}}" 
            data-text="{{base64Output}}" 
            data-key="b64-copy"
            bindtap="copyText"
          >{{copiedKey === 'b64-copy' ? '已复制 ✔' : '复制结果'}}</button>
        </view>
        <textarea 
          class="beautified-textarea text-mono" 
          placeholder="等待编解码操作..." 
          value="{{base64Output}}" 
          disabled 
          maxlength="-1"
        ></textarea>
      </view>
    </view>

    <!-- 3) COLOR CONVERTER -->
    <view class="color-converter-lab" wx:if="{{toolId === 'color-converter'}}">
      <!-- Dynamic color block deck -->
      <view class="color-deck-board animate-fade" style="background-color: {{hexColor}}; color: {{textColor}};">
        <view class="color-board-meta">
          <text class="board-hex text-mono">{{hexColor}}</text>
          <text class="board-flavor">春日工艺级色阶卡</text>
        </view>
        <button class="btn-circular shadow-md" bindtap="randomizeColor">
          <text class="circular-icon">✦</text>
        </button>
      </view>

      <view class="formats-list">
        <!-- Input section -->
        <view class="format-record">
          <view class="record-badge bg-primary-fixed">HEX (输入)</view>
          <input 
            class="record-input text-mono" 
            value="{{hexColor}}" 
            bindinput="onHexColorInput" 
            placeholder="#HEX色值"
            maxlength="7"
          />
          <button 
            class="record-copy" 
            data-text="{{hexColor}}" 
            data-key="hex-copy"
            bindtap="copyText"
          >{{copiedKey === 'hex-copy' ? '✓' : '复制'}}</button>
        </view>

        <!-- Dynamic outputs -->
        <view class="format-record">
          <view class="record-badge">RGB</view>
          <text class="record-val text-mono">{{rgbColor}}</text>
          <button 
            class="record-copy" 
            data-text="{{rgbColor}}" 
            data-key="rgb-copy"
            bindtap="copyText"
          >{{copiedKey === 'rgb-copy' ? '✓' : '复制'}}</button>
        </view>

        <view class="format-record">
          <view class="record-badge">HSL</view>
          <text class="record-val text-mono">{{hslColor}}</text>
          <button 
            class="record-copy" 
            data-text="{{hslColor}}" 
            data-key="hsl-copy"
            bindtap="copyText"
          >{{copiedKey === 'hsl-copy' ? '✓' : '复制'}}</button>
        </view>

        <view class="format-record">
          <view class="record-badge">CMYK</view>
          <text class="record-val text-mono">{{cmykColor}}</text>
          <button 
            class="record-copy" 
            data-text="{{cmykColor}}" 
            data-key="cmyk-copy"
            bindtap="copyText"
          >{{copiedKey === 'cmyk-copy' ? '✓' : '复制'}}</button>
        </view>
      </view>
    </view>

    <!-- 4) PASSWORD GENERATOR -->
    <view class="tool-card password-lab" wx:if="{{toolId === 'password'}}">
      
      <!-- Password container board -->
      <view class="password-dock-card shadow-sm border">
        <text class="password-display text-mono">{{passwordResult}}</text>
        <view class="dock-actions">
          <button 
            class="icon-action-btn border" 
            data-text="{{passwordResult}}" 
            data-key="pw-copy"
            bindtap="copyText"
          >{{copiedKey === 'pw-copy' ? '✓' : '复制'}}</button>
          <button class="icon-action-btn bg-p text-on-p" bindtap="generatePassword">换一个</button>
        </view>
      </view>

      <!-- Settings Panel -->
      <view class="pref-panel border mt-4">
        <view class="pref-row flex-between pb-3">
          <text class="pref-label font-bold text-sm">口令长度</text>
          <text class="pref-val text-mono text-primary font-black bg-p-dim">{{passwordLength}} 字符</text>
        </view>
        <slider 
          min="8" 
          max="32" 
          value="{{passwordLength}}" 
          activeColor="#446732" 
          backgroundColor="#F1F3EE" 
          block-color="#446732"
          block-size="18"
          bindchange="onLengthSelect"
          bindchanging="onLengthSelect"
        />

        <view class="divider-line mt-4 mb-4"></view>

        <view class="checkboxes-section flex flex-col gap-3">
          <label class="group flex-row items-center justify-between py-2">
            <text class="checkbox-label text-xs">大写英文字母 (A-Z)</text>
            <switch class="switch-small" checked="{{optUpper}}" color="#446732" data-opt="optUpper" bindchange="onOptChange"/>
          </label>
          <label class="group flex-row items-center justify-between py-2">
            <text class="checkbox-label text-xs">小写英文字母 (a-z)</text>
            <switch class="switch-small" checked="{{optLower}}" color="#446732" data-opt="optLower" bindchange="onOptChange"/>
          </label>
          <label class="group flex-row items-center justify-between py-2">
            <text class="checkbox-label text-xs">阿拉伯数字 (0-9)</text>
            <switch class="switch-small" checked="{{optNumber}}" color="#446732" data-opt="optNumber" bindchange="onOptChange"/>
          </label>
          <label class="group flex-row items-center justify-between py-2">
            <text class="checkbox-label text-xs">特殊安全字符 (!@#$)</text>
            <switch class="switch-small" checked="{{optSymbols}}" color="#446732" data-opt="optSymbols" bindchange="onOptChange"/>
          </label>
        </view>
      </view>
    </view>

    <!-- 5) POMODORO TIMER -->
    <view class="pomodoro-lab flex flex-col items-center justify-center p-3" wx:if="{{toolId === 'pomodoro'}}">
      
      <!-- Mode tabs switcher -->
      <view class="mode-navigator border">
        <view 
          class="mode-nav-btn {{pomodoroMode === 'focus' ? 'mode-active bg-primary text-on-p' : ''}}" 
          data-mode="focus" 
          bindtap="switchPomodoroMode"
        >专注学堂 (25m)</view>
        <view 
          class="mode-nav-btn {{pomodoroMode === 'break' ? 'mode-active bg-primary text-on-p' : ''}}" 
          data-mode="break" 
          bindtap="switchPomodoroMode"
        >悠游微休 (5m)</view>
      </view>

      <!-- Timer Ring Section -->
      <view class="timer-orb-shell border shadow-inner">
        <view class="pulse-ring {{pomodoroState === 'running' ? 'pulse-ani' : ''}}"></view>
        <view class="timer-text text-mono font-serif">{{pomodoroTime}}</view>
        <text class="timer-mode-sub">{{pomodoroMode === 'focus' ? '✧ 心流进行中 ✧' : '☂ 轻松片刻 ☂'}}</text>
      </view>

      <!-- Orb Control Panel -->
      <view class="orb-options flex-row gap-4 mt-6">
        <button 
          class="btn {{pomodoroState === 'running' ? 'btn-secondary' : 'btn-primary'}} flex-1 py-3 font-bold" 
          bindtap="startPausePomodoro"
        >
          {{pomodoroState === 'running' ? '暂停计时' : '开启心流'}}
        </button>
        <button class="btn btn-neutral border py-3 px-6 font-bold" bindtap="resetPomodoro">重置生命周期</button>
      </view>
    </view>

    <!-- 6) CASE CONVERTER -->
    <view class="tool-card case-lab" wx:if="{{toolId === 'case-converter'}}">
      <view class="input-deck">
        <text class="section-badge">在此粘贴你的文本 (INPUT)</text>
        <textarea 
          class="raw-json-textarea text-mono" 
          placeholder='例如: hello spring nest, welcome to wechat miniprogram...'
          value="{{caseInput}}"
          bindinput="onCaseInput"
          maxlength="-1"
        ></textarea>
      </view>

      <view class="grid-buttons flex-row pt-3 pb-3">
        <button class="btn btn-neutral text-xs py-2 px-1 flex-1 border" data-type="upper" bindtap="convertCase">全大写</button>
        <button class="btn btn-neutral text-xs py-2 px-1 flex-1 border" data-type="lower" bindtap="convertCase">全小写</button>
        <button class="btn btn-neutral text-xs py-2 px-1 flex-1 border" data-type="capitalize" bindtap="convertCase">首字母大写</button>
      </view>

      <view class="result-deck">
        <view class="result-header">
          <text class="result-title">转换处理输出 (OUTPUT)</text>
          <button 
            class="btn-text" 
            wx:if="{{caseOutput}}" 
            data-text="{{caseOutput}}" 
            data-key="case-copy"
            bindtap="copyText"
          >{{copiedKey === 'case-copy' ? '已复制 ✔' : '复制结果'}}</button>
        </view>
        <textarea 
          class="beautified-textarea text-mono" 
          placeholder="等待大小写格式编排..." 
          value="{{caseOutput}}" 
          disabled 
          maxlength="-1"
        ></textarea>
      </view>
    </view>

    <!-- 7) WORD COUNTER -->
    <view class="tool-card wc-lab" wx:if="{{toolId === 'word-counter'}}">
      <view class="input-deck">
        <textarea 
          class="raw-json-textarea text-mono h-200" 
          placeholder='在此键入或粘贴您需要进行指标统计分析的文本。我们将自动、在毫秒下为您测算出各项字数统计详情指标...'
          value="{{counterInput}}"
          bindinput="onCounterInput"
          maxlength="-1"
        ></textarea>
      </view>

      <view class="stats-docket mt-4 border shadow-sm rounded-2xl">
        <view class="docket-record">
          <text class="lbl text-xs text-primary font-bold">总字符数 (含空格)</text>
          <text class="val font-mono font-black text-on-surface">{{charCount}}</text>
        </view>
        <view class="docket-record">
          <text class="lbl text-xs text-primary font-bold">净字符数 (无空格)</text>
          <text class="val font-mono font-black text-on-surface">{{charNoSpace}}</text>
        </view>
        <view class="docket-record">
          <text class="lbl text-xs text-primary font-bold">言内词数 (中/英统计)</text>
          <text class="val font-mono font-black text-on-surface">{{wordCount}}</text>
        </view>
        <view class="docket-record">
          <text class="lbl text-xs text-primary font-bold">总行数 (LINES)</text>
          <text class="val font-mono font-black text-on-surface">{{lineCount}}</text>
        </view>
      </view>

      <view class="clear-action mt-4 flex justify-end">
        <button class="btn btn-neutral border py-2.5 px-6 shrink-0" bindtap="clearCounter">清空文本区间</button>
      </view>
    </view>

    <!-- 8) BOOKKEEPING LABORATORY -->
    <view class="bookkeeping-lab" wx:if="{{toolId === 'bookkeeping'}}">
      
      <!-- Balance indicator panel -->
      <view class="balance-card shadow-sm border bg-primary text-on-p">
        <view class="balance-meta">
          <text class="bal-label">心流自律账户余额 (BALANCE)</text>
          <text class="bal-value font-mono">￥{{bkBalance}}</text>
        </view>
        <view class="balance-logo">巢 ✦</view>
      </view>

      <!-- Ledger Entry Creator box -->
      <view class="ledger-box border mt-4 p-4 shadow-sm rounded-[24px]">
        <text class="section-title text-sm font-bold border-l-4 border-primary pl-2 mb-3">记一笔日常账目 (ENTRY)</text>
        
        <!-- Type Switch -->
        <view class="type-switcher border my-3">
          <view 
            class="switcher-item {{bkType === 'expense' ? 'switcher-active bg-primary' : ''}}" 
            data-type="expense"
            bindtap="onBkTypeChange"
          >支出 (- EXPENSE)</view>
          <view 
            class="switcher-item {{bkType === 'income' ? 'switcher-active bg-primary' : ''}}" 
            data-type="income"
            bindtap="onBkTypeChange"
          >收入 (+ INCOME)</view>
        </view>

        <!-- Form fields -->
        <view class="form-wrapper flex flex-col gap-3.5">
          <view class="form-row border">
            <text class="form-label text-xs">记账金额：</text>
            <input 
              type="digit" 
              class="form-input font-mono font-semibold" 
              placeholder="0.00" 
              value="{{bkAmount}}"
              bindinput="onBkAmountInput"
            />
          </view>
          <view class="form-row border">
            <text class="form-label text-xs">账目备注：</text>
            <input 
              type="text" 
              class="form-input" 
              placeholder="例如: 滴滴打车、下午茶" 
              value="{{bkNote}}"
              bindinput="onBkNoteInput"
            />
          </view>
          
          <button class="btn btn-primary mt-2" bindtap="addTransaction">添加记录</button>
        </view>
      </view>

      <!-- Records timeline docket -->
      <view class="records-docket border mt-4 shadow-sm rounded-[24px]">
        <text class="section-title text-sm font-bold border-l-4 border-primary pl-2 mb-3">流水分账明细 (LEDGER DETAILS)</text>
        
        <block wx:if="{{bkList.length > 0}}">
          <scroll-view scroll-y class="bk-scroll-timeline">
            <view class="bk-item border" wx:for="{{bkList}}" wx:key="id">
              <view class="bk-item-meta">
                <text class="item-notitle font-bold">{{item.note}}</text>
                <text class="item-date text-on-surface-variant font-mono">{{item.date}}</text>
              </view>
              <view class="bk-item-action">
                <text class="item-amt text-mono font-black {{item.type === 'income' ? 'text-success' : 'text-error'}}">
                  {{item.type === 'income' ? '+' : '-'}}￥{{item.amount}}
                </text>
                <button class="delete-btn-ledger" data-id="{{item.id}}" bindtap="deleteTransaction">×</button>
              </view>
            </view>
          </scroll-view>
        </block>
        <view class="no-records-panel flex flex-col items-center justify-center py-10 opacity-50" wx:else>
          <text class="no-records-art">✦</text>
          <text class="no-records-msg text-xs">尚无账单明细记录，开始规划记账吧~</text>
        </view>
      </view>
    </view>

  </view>
</view>
