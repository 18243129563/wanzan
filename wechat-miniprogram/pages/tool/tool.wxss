/* pages/tool/tool.wxss */

.tool-view-container {
  padding: 16px 20px 40px;
  background-color: #FBFDF8;
  min-height: 100vh;
  box-sizing: border-box;
}

/* Tool Header section */
.tool-badge-card {
  display: flex;
  flex-direction: column;
  margin-bottom: 24px;
}

.tool-meta-title {
  font-size: 24px;
  font-weight: 800;
  color: #191C1A;
  margin-bottom: 6px;
  letter-spacing: -0.5px;
}

.tool-meta-desc {
  font-size: 13px;
  color: #747878;
  line-height: 1.6;
}

.divider-line {
  height: 1px;
  background-color: rgba(116, 120, 120, 0.15);
  width: 100%;
  margin-top: 16px;
}

/* Tool Active Canvas */
.tool-active-canvas {
  width: 100%;
}

/* Base card layout */
.tool-card {
  background-color: #ffffff;
  border-radius: 28px;
  border: 1px solid rgba(116, 120, 120, 0.12);
  padding: 20px;
  box-sizing: border-box;
  margin-bottom: 20px;
}

/* Fallback card content */
.fallback-frame {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48px 24px;
  text-align: center;
  background-color: #ffffff;
  border-radius: 32px;
  border: 1px solid rgba(116, 120, 120, 0.15);
  margin-top: 24px;
}

.fallback-icon {
  font-size: 40px;
  color: #446732;
  margin-bottom: 16px;
  line-height: 1;
}

.fallback-heading {
  font-size: 18px;
  font-weight: bold;
  color: #191C1A;
  margin-bottom: 8px;
}

.fallback-paragraph {
  font-size: 13px;
  color: #747878;
  line-height: 1.7;
}

/* Shared form elements */
.input-deck {
  display: flex;
  flex-direction: column;
  margin-bottom: 16px;
}

.section-badge {
  font-size: 10px;
  font-weight: 700;
  color: #446732;
  letter-spacing: 1px;
  margin-bottom: 8px;
}

.raw-json-textarea {
  width: 100%;
  height: 140px;
  background-color: #F1F3EE;
  border-radius: 20px;
  padding: 14px;
  font-size: 13px;
  line-height: 1.6;
  color: #191C1A;
  box-sizing: border-box;
}

.beautified-textarea {
  width: 100%;
  height: 200px;
  background-color: #F1F3EE;
  border-radius: 20px;
  padding: 14px;
  font-size: 12px;
  line-height: 1.6;
  color: #191C1A;
  box-sizing: border-box;
}

.h-200 {
  height: 200px !important;
}

.text-mono {
  font-family: ui-monospace, SFMono-Regular, monospace;
}

/* Buttons */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 100px;
  font-size: 14px;
  font-weight: bold;
  height: 48px;
  box-shadow: none;
  width: 100%;
  box-sizing: border-box;
}

.btn-primary {
  background-color: #446732;
  color: #ffffff;
}

.btn-secondary {
  background-color: #D3E8D0;
  color: #111E0F;
}

.btn-neutral {
  background-color: #F1F3EE;
  color: #191C1A;
}

.btn-text {
  background: none;
  background-color: transparent !important;
  border: none;
  font-size: 12px;
  font-weight: 800;
  color: #446732;
  padding: 0 4px;
  line-height: 1;
}

.grid-buttons {
  display: flex;
  gap: 12px;
  margin-bottom: 16px;
}

.flex-row {
  display: flex;
  flex-direction: row;
}

.flex-1 {
  flex: 1;
}

.pt-3 { padding-top: 12px; }
.pb-3 { padding-bottom: 12px; }
.mt-4 { margin-top: 16px; }
.mb-4 { margin-bottom: 16px; }
.mt-6 { margin-top: 24px; }

/* Result Block output */
.result-deck {
  display: flex;
  flex-direction: column;
  background-color: #ffffff;
  border-radius: 24px;
  border: 1px solid rgba(116, 120, 120, 0.12);
  padding: 16px;
  box-sizing: border-box;
  margin-top: 16px;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
  border-bottom: 1px solid rgba(116, 120, 120, 0.08);
  padding-bottom: 8px;
}

.result-title {
  font-size: 11px;
  font-weight: 700;
  color: #747878;
  letter-spacing: 0.5px;
}

.text-error {
  color: #BA1A1A;
}

.text-success {
  color: #2F3B2B;
}

.border-error {
  border-color: #FFB4AB !important;
}

.scroll-wrap {
  width: 100%;
  padding: 12px;
  background-color: #FFDAD6;
  border-radius: 16px;
  box-sizing: border-box;
  font-size: 12px;
  line-height: 1.6;
}

/* ==========================================
   3) COLOR CONVERTER STYLES
   ========================================== */
.color-deck-board {
  height: 160px;
  width: 100%;
  border-radius: 32px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.06);
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 24px;
  box-sizing: border-box;
  margin-bottom: 24px;
  position: relative;
  transition: all 0.3s ease;
  border: 1px solid rgba(255, 255, 255, 0.15);
}

.color-board-meta {
  display: flex;
  flex-direction: column;
}

.board-hex {
  font-size: 26px;
  font-weight: 900;
  letter-spacing: 1px;
  line-height: 1;
  margin-bottom: 4px;
}

.board-flavor {
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  opacity: 0.82;
  font-weight: 600;
}

.btn-circular {
  width: 44px;
  height: 44px;
  border-radius: 100px;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.15);
  padding: 0;
  margin: 0;
}

.circular-icon {
  font-size: 18px;
  color: inherit;
  font-weight: bold;
}

.formats-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.format-record {
  background-color: #ffffff;
  border: 1px solid rgba(116, 120, 120, 0.12);
  padding: 12px 16px;
  border-radius: 20px;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.record-badge {
  font-size: 10px;
  font-weight: bold;
  color: #446732;
  padding: 4px 8px;
  background-color: #F1F3EE;
  border-radius: 6px;
  margin-right: 12px;
  flex-shrink: 0;
}

.record-val {
  font-size: 13px;
  font-weight: 600;
  color: #191C1A;
  flex-grow: 1;
}

.record-input {
  font-size: 13px;
  font-weight: 600;
  color: #191C1A;
  flex-grow: 1;
  height: 24px;
}

.record-copy {
  font-size: 11px;
  font-weight: 800;
  color: #446732;
  border: none !important;
  background: none !important;
  padding: 0;
  margin: 0;
  background-color: transparent !important;
}

/* ==========================================
   4) PASSWORD GENERATOR STYLES
   ========================================== */
.password-dock-card {
  background-color: #ffffff;
  padding: 16px;
  border-radius: 24px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-sizing: border-box;
}

.password-display {
  font-size: 15px;
  font-weight: 800;
  color: #446732;
  word-break: break-all;
  flex-grow: 1;
  margin-right: 12px;
  letter-spacing: 0.5px;
}

.dock-actions {
  display: flex;
  gap: 6px;
  flex-shrink: 0;
}

.icon-action-btn {
  font-size: 12px;
  font-weight: 700;
  padding: 6px 12px;
  border-radius: 12px;
  height: 34px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
}

.icon-action-btn.border {
  border: 1px solid rgba(116, 120, 120, 0.15);
  background-color: #F1F3EE;
  color: #191C1A;
}

.bg-p {
  background-color: #446732 !important;
}

.text-on-p {
  color: #ffffff !important;
}

.pref-panel {
  background-color: #ffffff;
  padding: 20px;
  border-radius: 28px;
  box-sizing: border-box;
}

.border {
  border: 1px solid rgba(116, 120, 120, 0.12);
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.pref-label {
  font-size: 13px;
  font-weight: 700;
  color: #191C1A;
}

.pref-val {
  font-size: 12px;
  font-weight: 900;
  color: #446732;
  padding: 4px 10px;
  background-color: #F1F3EE;
  border-radius: 40px;
}

.checkbox-label {
  font-size: 12px;
  font-weight: 600;
  color: #747878;
}

.switch-small {
  transform: scale(0.85);
  margin-right: -4px;
}

/* ==========================================
   5) POMODORO TIMER STYLES
   ========================================== */
.mode-navigator {
  background-color: #F1F3EE;
  padding: 4px;
  border-radius: 100px;
  display: flex;
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 30px;
}

.mode-nav-btn {
  flex-grow: 1;
  text-align: center;
  padding: 10px 12px;
  font-size: 12px;
  font-weight: bold;
  border-radius: 100px;
  color: #747878;
  box-sizing: border-box;
}

.mode-active {
  background-color: #446732;
  color: #ffffff;
}

.timer-orb-shell {
  width: 240px;
  height: 240px;
  border-radius: 50% !important;
  background-color: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  margin-bottom: 24px;
}

.pulse-ring {
  position: absolute;
  top: 0;
  left: 0;
  width: 240px;
  height: 240px;
  border-radius: 50%;
  border: 1px solid #446732;
  opacity: 0;
  pointer-events: none;
}

@keyframes pulse {
  0% {
    transform: scale(0.97);
    opacity: 0.8;
  }
  100% {
    transform: scale(1.1);
    opacity: 0;
  }
}

.pulse-ani {
  animation: pulse 2s infinite ease-out;
}

.timer-text {
  font-size: 46px;
  font-weight: 300;
  color: #446732;
  margin-bottom: 4px;
}

.timer-mode-sub {
  font-size: 10px;
  font-weight: bold;
  letter-spacing: 1px;
  color: #747878;
}

.orb-options {
  display: flex;
  width: 100%;
  gap: 12px;
  box-sizing: border-box;
}

/* ==========================================
   7) WORD COUNTER STYLES
   ========================================== */
.stats-docket {
  background-color: #ffffff;
  border-radius: 20px;
  padding: 4px;
}

.docket-record {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 16px;
  border-bottom: 1px solid rgba(116, 120, 120, 0.08);
}

.docket-record:last-child {
  border-bottom: none;
}

.stats-docket .lbl {
  font-size: 12px;
  font-weight: 700;
  color: #446732;
}

.stats-docket .val {
  font-size: 15px;
  font-weight: 900;
  color: #191C1A;
}

/* ==========================================
   8) BOOKKEEPING STYLES
   ========================================== */
.balance-card {
  padding: 24px;
  border-radius: 32px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-sizing: border-box;
  background-color: #446732;
  color: #ffffff;
}

.balance-meta {
  display: flex;
  flex-direction: column;
}

.bal-label {
  font-size: 10px;
  font-weight: bold;
  letter-spacing: 1px;
  opacity: 0.8;
  margin-bottom: 6px;
}

.bal-value {
  font-size: 32px;
  font-weight: 800;
}

.balance-logo {
  font-size: 20px;
  font-weight: bold;
  opacity: 0.85;
}

.ledger-box, .records-docket {
  background-color: #ffffff;
  padding: 20px;
  border-radius: 28px;
  box-sizing: border-box;
}

.type-switcher {
  display: flex;
  background-color: #F1F3EE;
  padding: 3px;
  border-radius: 100px;
}

.switcher-item {
  flex-grow: 1;
  text-align: center;
  padding: 8px 12px;
  font-size: 11px;
  font-weight: bold;
  border-radius: 100px;
  color: #747878;
}

.switcher-active {
  background-color: #446732;
  color: #ffffff;
}

.form-wrapper {
  display: flex;
  flex-direction: column;
}

.form-row {
  display: flex;
  align-items: center;
  padding: 10px 14px;
  border-radius: 16px;
  background-color: #fffffff;
}

.form-label {
  font-size: 12px;
  font-weight: bold;
  color: #747878;
  flex-shrink: 0;
  width: 70px;
}

.form-input {
  font-size: 13px;
  color: #191C1A;
  flex-grow: 1;
}

.bk-scroll-timeline {
  max-h: 240px;
  width: 100%;
}

.bk-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 14px;
  border-radius: 16px;
  margin-bottom: 8px;
  background-color: #FBFDF8;
}

.bk-item-meta {
  display: flex;
  flex-direction: column;
}

.item-notitle {
  font-size: 13px;
  color: #191C1A;
  margin-bottom: 3px;
}

.item-date {
  font-size: 10px;
  color: #747878;
}

.bk-item-action {
  display: flex;
  align-items: center;
  gap: 12px;
}

.item-amt {
  font-size: 14px;
  font-weight: 800;
}

.delete-btn-ledger {
  width: 18px;
  height: 18px;
  border-radius: 100px;
  background-color: #F1F3EE;
  color: #BA1A1A;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  padding: 0;
  margin: 0;
  line-height: 1;
  border: none;
}

.no-records-art {
  font-size: 24px;
  color: #446732;
  margin-bottom: 6px;
}

.no-records-msg {
  color: #747878;
}
