<!--pages/discover/discover.wxml-->
<view class="discover-root-viewport">
  
  <!-- App Branding Greeting -->
  <view class="branding-header animate-[fadeIn_0.5s]">
    <view class="branding-brand">
      <view class="branding-icon-leaf">🌿</view>
      <text class="branding-title">春日小筑</text>
    </view>
    <text class="branding-subtext">Spring Nest · 每一个小组件都倾注美学温度</text>
  </view>

  <!-- Fluent Search Bar -->
  <view class="search-wrap">
    <icon type="search" size="14" class="search-inner-icon"></icon>
    <input 
      type="text" 
      class="search-input-field" 
      placeholder="搜索感兴趣的精品小工具、生活指南..." 
      value="{{searchQuery}}" 
      bindinput="onSearchInput" 
    />
  </view>

  <!-- SEARCH RESULTS VIEWPORT -->
  <block wx:if="{{searchQuery}}">
    <view class="search-viewpane mt-4 animate-fade">
      <text class="section-heading">搜索结果 ({{filteredTools.length}})</text>
      
      <view class="results-rows-list" wx:if="{{filteredTools.length > 0}}">
        <view class="search-row border" wx:for="{{filteredTools}}" wx:key="id" bindtap="onToolSelect" data-id="{{item.id}}">
          <view class="row-prefix">✦</view>
          <view class="row-main">
            <text class="row-name">{{item.name}}</text>
            <text class="row-desc">{{item.desc}}</text>
          </view>
          <text class="row-arrow">➔</text>
        </view>
      </view>

      <view class="empty-search-fallback" wx:else>
        <text class="f-icon">🔍</text>
        <text class="f-title">未找到相似工具</text>
        <text class="f-sub">检查输入字符，或看看页面推荐吧~</text>
      </view>
    </view>
  </block>

  <!-- MAIN TAB PANELS -->
  <block wx:else>
    
    <!-- 1) POPULAR FAVORITES ROW -->
    <view class="pane-section mt-4">
      <text class="section-heading">常用工具</text>
      <view class="favorites-scroll-bar">
        <view 
          class="favorite-mini-card shadow-sm border" 
          wx:for="{{favorites}}" 
          wx:key="id" 
          bindtap="onToolSelect" 
          data-id="{{item.id}}"
        >
          <view class="fav-icon-box {{item.color}}">
            <text class="icon-glyph">{{item.iconArt}}</text>
          </view>
          <text class="fav-mini-title">{{item.name}}</text>
        </view>
      </view>
    </view>

    <!-- 2) DAILY TOOLS BENTO GRID -->
    <view class="pane-section mt-6">
      <view class="title-with-badge">
        <text class="badge-dot p-indicator"></text>
        <text class="section-heading">日常实用</text>
      </view>
      
      <view class="bento-grid">
        <view 
          class="bento-card border shadow-sm" 
          wx:for="{{dailyTools}}" 
          wx:key="id" 
          bindtap="onToolSelect" 
          data-id="{{item.id}}"
        >
          <view class="bento-emoji-wrapper" style="background-color: {{item.colorBg}};">
            <text class="bento-emoji">{{item.iconText}}</text>
          </view>
          <view class="bento-details">
            <text class="bento-tool-name">{{item.name}}</text>
            <text class="bento-tool-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 3) FUN TOOLS GRID -->
    <view class="pane-section mt-6">
      <view class="title-with-badge">
        <text class="badge-dot t-indicator"></text>
        <text class="section-heading">趣味工具</text>
      </view>
      
      <view class="bento-grid">
        <view 
          class="bento-card border shadow-sm" 
          wx:for="{{funTools}}" 
          wx:key="id" 
          bindtap="onToolSelect" 
          data-id="{{item.id}}"
        >
          <view class="bento-emoji-wrapper" style="background-color: {{item.colorBg}};">
            <text class="bento-emoji">{{item.iconText}}</text>
          </view>
          <view class="bento-details">
            <text class="bento-tool-name">{{item.name}}</text>
            <text class="bento-tool-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
    </view>

  </block>
</view>
