/* pages/discover/discover.wxss */

.discover-root-viewport {
  padding: 12px 20px 40px;
  background-color: #FBFDF8;
  min-height: 100vh;
  box-sizing: border-box;
}

/* Brand Header */
.branding-header {
  display: flex;
  flex-direction: column;
  margin-bottom: 20px;
}

.branding-brand {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 4px;
}

.branding-icon-leaf {
  font-size: 24px;
  line-height: 1;
}

.branding-title {
  font-size: 24px;
  font-weight: 900;
  color: #446732;
  letter-spacing: -0.5px;
}

.branding-subtext {
  font-size: 11px;
  color: #747878;
  font-weight: bold;
}

/* Search wrap */
.search-wrap {
  position: relative;
  width: 100%;
  margin-bottom: 24px;
}

.search-inner-icon {
  position: absolute;
  left: 18px;
  top: 15px;
  z-index: 10;
}

.search-input-field {
  height: 46px;
  background-color: #F1F3EE;
  border-radius: 24px;
  padding: 0 46px;
  font-size: 13px;
  border: 1px solid rgba(116, 120, 120, 0.08);
  box-sizing: border-box;
  color: #191C1A;
}

/* Section Headings */
.section-heading {
  font-size: 16px;
  font-weight: bold;
  color: #191C1A;
  margin-bottom: 12px;
}

.title-with-badge {
  display: flex;
  align-items: center;
  gap: 8px;
}

.badge-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
}

.p-indicator { background-color: #446732; }
.t-indicator { background-color: #7A5749; }

/* Favorites Scroll Layout */
.favorites-scroll-bar {
  display: flex;
  gap: 12px;
  width: 100%;
  overflow-x: auto;
  padding-bottom: 4px;
}

.favorite-mini-card {
  flex-shrink: 0;
  width: 104px;
  background-color: #ffffff;
  border-radius: 20px;
  padding: 14px 10px;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

.border {
  border: 1px solid rgba(116, 120, 120, 0.12);
}

.shadow-sm {
  box-shadow: 0 2px 8px rgba(0,0,0,0.03);
}

.fav-icon-box {
  width: 44px;
  height: 44px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8px;
  box-shadow: inset 0 2px 4px rgba(255,255,255,0.2);
}

.icon-glyph {
  font-size: 20px;
}

.bg-p-dim { background-color: rgba(68, 103, 50, 0.12); }
.bg-s-dim { background-color: rgba(68, 103, 50, 0.05); }
.bg-t-dim { background-color: rgba(122, 87, 73, 0.12); }

.fav-mini-title {
  font-size: 11px;
  font-weight: 800;
  color: #191C1A;
}

/* Bento Grid */
.bento-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.bento-card {
  width: calc(50% - 6px);
  background-color: #ffffff;
  border-radius: 20px;
  padding: 14px;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 118px;
}

.bento-emoji-wrapper {
  width: 36px;
  height: 36px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12px;
}

.bento-emoji {
  font-size: 18px;
}

.bento-tool-name {
  font-size: 13px;
  font-weight: 700;
  color: #191C1A;
  display: block;
}

.bento-tool-desc {
  font-size: 10px;
  color: #747878;
  display: block;
  margin-top: 3px;
  line-height: 1.3;
}

/* Search results panel list */
.results-rows-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.search-row {
  background-color: #ffffff;
  border-radius: 16px;
  padding: 12px 14px;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.row-prefix {
  font-size: 14px;
  color: #446732;
  margin-right: 12px;
  font-weight: bold;
}

.row-main {
  flex-grow: 1;
  display: flex;
  flex-direction: column;
}

.row-name {
  font-size: 13px;
  font-weight: bold;
  color: #191C1A;
  margin-bottom: 2px;
}

.row-desc {
  font-size: 10px;
  color: #747878;
}

.row-arrow {
  font-size: 12px;
  color: #747878;
  opacity: 0.5;
}

/* Fallbacks */
.empty-search-fallback {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40px 20px;
  text-align: center;
}

.f-icon {
  font-size: 32px;
  margin-bottom: 12px;
}

.f-title {
  font-size: 14px;
  font-weight: Bold;
  color: #191C1A;
  margin-bottom: 4px;
}

.f-sub {
  font-size: 11px;
  color: #747878;
}

.mt-4 { margin-top: 16px; }
.mt-6 { margin-top: 24px; }
